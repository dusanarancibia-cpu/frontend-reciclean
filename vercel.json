{
  "framework": null,
  "buildCommand": "npm run build:css",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
